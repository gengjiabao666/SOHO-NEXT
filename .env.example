# ============================================================
# Echotik 采集器 - 环境变量配置示例
# 使用说明：复制此文件为 .env，填入真实值，.env 不可提交到 git
# ============================================================

# ---------- Echotik 账号（支持多账号，逗号分隔） ----------
ECHOTIK_ACCOUNTS=user1@example.com,user2@example.com
ECHOTIK_PASSWORDS=password1,password2

# ---------- 报警通知 Webhook（企微或飞书二选一，不用的留空） ----------
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxxxxxx
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx

# ---------- 路径配置 ----------
REPO_ROOT=/mnt/g/SOHO_repo
PIPELINE_SCRIPT=/home/gjb/workspace/echotik_pipeline.py

# ---------- Python 解释器路径（重要）----------
# 获取方法：conda activate echotik && which python
PYTHON_BIN=/home/gjb/miniconda3/envs/echotik/bin/python

# ---------- 代理设置（WSL2 重要配置）----------
# Playwright 启动的 Chromium 不会自动继承终端代理，需在此处配置。
# WSL2 每次重启 Windows 宿主机 IP 都会变，推荐使用 PROXY_PORT 方式：
#   脚本会自动获取当前宿主机 IP，和 PROXY_PORT 拼成完整代理地址。
#   等价于 bashrc 里的 proxy_on 逻辑。
#
# 方式A（推荐）：只填端口，IP 自动获取
PROXY_PORT=10808
#
# 方式B：手动填完整地址（IP 变了需要手动更新）
# PLAYWRIGHT_PROXY=http://172.26.96.1:10808

# ============================================================
# 页面异常检测模块
# ============================================================

# 选择检测方式：rule / qwen / claude / openai / gemini / kimi
ANOMALY_PROVIDER=rule

# ------------------------------------------------------------------
# 各提供商配置说明
#
# 每个提供商有两个配置项：
#   {NAME}_API_KEY   - API 密钥（必填，使用该提供商时）
#   {NAME}_BASE_URL  - API 地址（可选）
#
# BASE_URL 的使用场景：
#   1. 使用第三方 API 转发服务时，填写转发服务的地址
#   2. 使用自建代理时，填写代理地址
#   3. 不填则使用各提供商官方默认地址
#
# 第三方转发服务通常提供：
#   - 一个 API 地址（如 https://api.your-provider.com/v1）
#   - 一个 API Key
#   - 支持的模型名称列表
# 两项都填写才能正常使用第三方服务。
# ------------------------------------------------------------------

# ---------- Qwen（推荐：国内稳定，专为网页/UI截图训练） ----------
# 官方地址：https://dashscope.aliyuncs.com/compatible-mode/v1
# 模型选项：qwen3.5-plus / qwen3-vl-plus / qwen3-vl-flash / qwen-vl-max / qwen-vl-plus
QWEN_API_KEY=
QWEN_MODEL=qwen3.5-plus
QWEN_BASE_URL=                    # 留空使用官方地址，填入第三方转发地址则使用第三方

# ---------- Claude（Anthropic） ----------
# 官方地址：https://api.anthropic.com
# 需额外安装：pip install anthropic
# 模型选项：claude-sonnet-4-5 / claude-opus-4-5
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5
ANTHROPIC_BASE_URL=               # 留空使用官方地址

# ---------- OpenAI（ChatGPT） ----------
# 官方地址：https://api.openai.com/v1
# 模型选项：gpt-4o-mini / gpt-4o
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=                  # 留空使用官方地址，第三方转发填此处

# ---------- Gemini（Google） ----------
# 官方地址：https://generativelanguage.googleapis.com/v1beta
# 模型选项：gemini-1.5-flash / gemini-1.5-pro
# 注意：Gemini 原生 API 格式与其他提供商不同
# 若第三方代理兼容 OpenAI 格式，建议改用 ANOMALY_PROVIDER=openai 对接
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_BASE_URL=                  # 留空使用官方地址

# ---------- Kimi（Moonshot） ----------
# 官方地址：https://api.moonshot.cn/v1
# 模型选项：moonshot-v1-8k-vision / moonshot-v1-32k-vision
KIMI_API_KEY=
KIMI_MODEL=moonshot-v1-8k-vision
KIMI_BASE_URL=                    # 留空使用官方地址
